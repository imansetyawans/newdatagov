# Render backend environment
#
# Use one PostgreSQL URL from Supabase or Neon. The app will reuse it for all
# DataGov metadata modules unless a specific *_DATABASE_URL is set.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres

# Set this to the final Vercel URL after frontend deployment.
# Keep JSON-list format for pydantic-settings.
CORS_ORIGINS=["https://your-datagov-app.vercel.app"]

SECRET_KEY=replace-with-a-long-random-secret
DEBUG=false
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Optional. If omitted, the app uses local fallback metadata generation.
OPENAI_API_KEY=
AI_METADATA_MODEL=gpt-5-mini
